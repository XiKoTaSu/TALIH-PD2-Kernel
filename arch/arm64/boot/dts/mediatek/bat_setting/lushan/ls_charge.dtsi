&mt6360_chg {
	ieoc = <200000>; /* uA */
	mivr = <4400000>;/* uV */
	cv = <4400000>;	/* uA */
	ircmp_resistor = <0>;
	ircmp_vclamp = <0>;
};
#include "mtk_pe50.dtsi"
